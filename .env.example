# =============================================================
# SocialMind - Environment Variables
# Copy this to .env.local and fill in your real values
# =============================================================

# --- AI BRAIN (REQUIRED) ---
OPENAI_API_KEY=sk-proj-...

# --- DATABASE (Supabase free tier) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- APP URL (set this in Vercel to your deployed URL) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- FACEBOOK / INSTAGRAM (Meta Graph API) ---
# Get from https://developers.facebook.com/apps
META_APP_ID=
META_APP_SECRET=
# OAuth callback: $NEXT_PUBLIC_APP_URL/api/auth/facebook/callback

# --- TIKTOK (Content Posting API) ---
# Get from https://developers.tiktok.com/apps
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# OAuth callback: $NEXT_PUBLIC_APP_URL/api/auth/tiktok/callback

# --- YOUTUBE (Google Cloud OAuth) ---
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# OAuth callback: $NEXT_PUBLIC_APP_URL/api/auth/youtube/callback

# --- ENCRYPTION (for storing OAuth tokens at rest) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
